@startuml
title Diseño — editarSolicitudDispensa() (Secretaria)

actor Secretaria as S

box "Frontend (React + TS)" #E8F0FE
    participant "EditarSolicitudDispensaSecretariaPage" as ESP
    participant "dispensasService" as DS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "DispensasRouter\nPATCH /dispensas/{id}" as DR
    participant "require_rol" as RR
    participant "SolicitudDispensaService" as SDS
    participant "SolicitudDispensaRepository" as SDR
end box

database "SQLite" as DB

S   -> ESP  : modificar motivo / asig matr / cancelar
ESP -> DS   : actualizar(id, datos)
DS  -> DR   : PATCH /dispensas/{id} (Bearer)
DR  -> RR   : autorizar ["alumno", "secretaria", "director"]
RR  --> DR  : Secretaria | 403
DR  -> SDS  : actualizar(id, datos, current_user)
SDS -> SDR  : obtener_por_id(id)
SDR --> SDS : SolicitudDispensa

alt operación permitida por PoliticaSecretaria
    SDS -> SDR : actualizar(solicitud, cambios)
    SDR -> DB  : UPDATE
    DB  --> SDR : SolicitudDispensa
    SDR --> SDS : SolicitudDispensa
    SDS --> DR : SolicitudDispensaOut
    DR  --> DS : 200
    DS  --> ESP : actualizada
    ESP --> S   : navigate("/dispensas/{id}")
else campo no editable / transición ilegal
    SDS --> DR : raise CampoNoEditable | TransicionNoValida
    DR  --> DS : 422
    DS  --> ESP : error
    ESP --> S   : mensaje
end

@enduml
