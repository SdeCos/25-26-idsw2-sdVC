@startuml
title Diseño — crearAlumno()

actor Secretaria as S

box "Frontend (React + TS)" #E8F0FE
    participant "CrearAlumnoPage" as CP
    participant "alumnosService" as AS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "AlumnosRouter\nPOST /alumnos" as AR
    participant "require_rol" as RR
    participant "UsuarioService" as USv
    participant "UsuarioRepository" as URe
end box

database "SQLite" as DB

S   -> CP   : login, contraseña, datos
CP  -> AS   : crear(datos)
AS  -> AR   : POST /alumnos (Bearer)
AR  -> RR   : autorizar "secretaria"
RR  --> AR  : Secretaria | 403
AR  -> USv  : crear(tipo="alumno", datos)
USv -> URe  : crear(tipo, login, password_hash, datos_personales)
URe -> DB   : INSERT (subtipo alumno)

alt login libre
    DB  --> URe : Alumno
    URe --> USv : Alumno
    USv --> AR  : AlumnoOut
    AR  --> AS  : 201
    AS  --> CP  : alumno creado
    CP  --> S   : navigate("/alumnos")
else login en uso
    DB  --> URe : IntegrityError
    URe --> USv : raise UsernameEnUso
    USv --> AR  : raise
    AR  --> AS  : 409
    AS  --> CP  : error
    CP  --> S   : "ese login ya existe"
end

@enduml
