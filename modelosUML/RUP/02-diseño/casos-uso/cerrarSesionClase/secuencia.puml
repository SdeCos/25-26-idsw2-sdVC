@startuml
title Diseño — cerrarSesionClase()

actor Profesor as P

box "Frontend (React + TS)" #E8F0FE
    participant "SesionClaseActivaPage\n(modal Finalizar)" as SP
    participant "sesionesClaseService" as SS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "SesionesClaseRouter\nPATCH /sesiones-clase/{id}" as SR
    participant "require_rol" as RR
    participant "SesionClaseService" as SCS
    participant "SesionClaseRepository" as SCR
end box

database "SQLite" as DB

P  -> SP  : "Sí, continuar" en modal
SP -> SS  : actualizar(id, {estado: "CERRADA"})
SS -> SR  : PATCH /sesiones-clase/{id} (Bearer)
SR -> RR  : autorizar "profesor"
RR --> SR : Profesor | 403
SR -> SCS : actualizar(id, cambios, current_user)
SCS -> SCR : obtener_por_id(id)
SCR --> SCS : SesionDeClase

alt transición válida (ABIERTA → CERRADA, propietario)
    SCS -> SCS : sellar hora_fin = ahora
    SCS -> SCR : actualizar(sesion, {estado: CERRADA, hora_fin: now})
    SCR -> DB  : UPDATE
    DB  --> SCR : SesionDeClase
    SCR --> SCS : SesionDeClase
    SCS --> SR  : SesionDeClaseOut
    SR  --> SS  : 200
    SS  --> SP  : cerrada
    SP  --> P   : navigate("/sesiones-clase")
else estado != ABIERTA o no propietario
    SCS --> SR  : raise SesionClaseNoEditable
    SR  --> SS  : 422 / 403
    SS  --> SP  : error
    SP  --> P   : "no se puede cerrar esta sesión"
end

@enduml
