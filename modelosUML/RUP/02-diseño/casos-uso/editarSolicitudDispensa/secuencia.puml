@startuml
title Diseño — editarSolicitudDispensa() (Alumno)

actor Alumno as A

box "Frontend (React + TS)" #E8F0FE
    participant "EditarSolicitudPage" as ESP
    participant "dispensasService" as DS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "DispensasRouter\nPATCH /dispensas/{id}" as DR
    participant "require_rol" as RR
    participant "SolicitudDispensaService" as SDS
    participant "SolicitudDispensaRepository" as SDR
end box

database "SQLite" as DB

A   -> ESP  : editar campos / cancelar
ESP -> DS   : actualizar(id, datos)
DS  -> DR   : PATCH /dispensas/{id} (Bearer)
DR  -> RR   : autorizar "alumno"
RR  --> DR  : Alumno | 403
DR  -> SDS  : actualizar(id, datos, alumno)
SDS -> SDR  : obtener_por_id(id)
SDR --> SDS : SolicitudDispensa

alt operación permitida por PoliticaAlumno
    SDS -> SDR : actualizar(solicitud, cambios)
    SDR -> DB  : UPDATE
    DB  --> SDR : SolicitudDispensa
    SDR --> SDS : SolicitudDispensa
    SDS --> DR : SolicitudDispensaOut
    DR  --> DS : 200
    DS  --> ESP : actualizada
    ESP --> A   : navigate("/dispensas/{id}")
else no propia / campo no editable / transición ilegal
    SDS --> DR : raise NoAutorizado | CampoNoEditable | TransicionNoValida
    DR  --> DS : 403 | 422
    DS  --> ESP : error
    ESP --> A   : mensaje
end

@enduml
