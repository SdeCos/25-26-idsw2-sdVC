@startuml consultarListaAlumnos-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":Listas Abierto" as ListasAbierto

package consultarListaAlumnos as "consultarListaAlumnos()" {
    rectangle #629EF9 ConsultarListaAlumnosView
    rectangle #b5bd68 AlumnoController
    rectangle #F2AC4E AlumnoRepository
    rectangle #F2AC4E Alumno
}

ListasAbierto -r-> ConsultarListaAlumnosView    : consultarListaAlumnos(asignatura)

ConsultarListaAlumnosView -d-> AlumnoController : cargarLista(asignatura) : List<Alumno>

AlumnoController --> AlumnoRepository           : obtenerPorAsignatura(asignatura) : List<Alumno>

AlumnoRepository -- Alumno

@enduml
