@startuml
title Diseño — consultarSolicitudDispensa() (Secretaria)

actor Secretaria as S

box "Frontend (React + TS)" #E8F0FE
    participant "ConsultarDispensaPage" as CDP
    participant "dispensasService" as DS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "DispensasRouter\nGET /dispensas/{id}" as DR
    participant "require_rol" as RR
    participant "SolicitudDispensaService" as SDS
    participant "SolicitudDispensaRepository" as SDR
end box

database "SQLite" as DB

S   -> CDP  : entrar a /dispensas/{id}
CDP -> DS   : obtener(id)
DS  -> DR   : GET /dispensas/{id} (Bearer)
DR  -> RR   : autorizar ["alumno", "secretaria", "director"]
RR  --> DR  : Secretaria | 403
DR  -> SDS  : obtener(id, current_user)
SDS -> SDR  : obtener_por_id(id)
SDR -> DB   : SELECT JOIN alumno + asignatura matriculada + asignatura + responsable

alt encontrada
    DB  --> SDR : SolicitudDispensa
    SDR --> SDS : SolicitudDispensa
    SDS --> DR  : SolicitudDispensaDetalleOut
    DR  --> DS  : 200
    DS  --> CDP : ficha
    CDP --> S   : ficha enriquecida (alumno + asignatura + responsable)
else no existe
    DB  --> SDR : None
    SDR --> SDS : None
    SDS --> DR  : raise NoEncontrada
    DR  --> DS  : 404
    DS  --> CDP : error
    CDP --> S   : "no encontrada"
end

@enduml
