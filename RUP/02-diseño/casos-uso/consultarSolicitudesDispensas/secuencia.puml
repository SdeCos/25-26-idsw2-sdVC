@startuml
title Diseño — consultarSolicitudesDispensas()

actor Director as D

box "Frontend (React + TS)" #E8F0FE
    participant "ConsultarDispensaPage" as CDP
    participant "dispensasService" as DS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "DispensasRouter\nGET /dispensas/{id}" as DR
    participant "require_rol" as RR
    participant "SolicitudDispensaRepository" as SDR
end box

database "SQLite" as DB

D   -> CDP  : abrir ficha {id}
CDP -> DS   : obtener(id)
DS  -> DR   : GET /dispensas/{id} (Bearer)
DR  -> RR   : autorizar "director"
RR  --> DR  : Director | 403
DR  -> SDR  : obtener_por_id(id)
SDR -> DB   : SELECT JOIN alumno

alt encontrada
    DB  --> SDR : SolicitudDispensa
    SDR --> DR  : SolicitudDispensa
    DR  --> DS  : 200 + SolicitudDispensaDetalleOut
    DS  --> CDP : solicitud
    CDP --> D   : ficha + acción según estado
else no existe
    DB  --> SDR : None
    SDR --> DR  : None
    DR  --> DS  : 404
    DS  --> CDP : error
    CDP --> D   : "solicitud no encontrada"
end

@enduml
