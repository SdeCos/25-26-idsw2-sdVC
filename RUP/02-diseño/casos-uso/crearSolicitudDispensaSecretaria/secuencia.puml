@startuml
title Diseño — crearSolicitudDispensa() (Secretaria)

actor Secretaria as S

box "Frontend (React + TS)" #E8F0FE
    participant "CrearSolicitudDispensaSecretariaPage" as CP
    participant "dispensasService" as DS
end box

box "Backend (FastAPI)" #FFF4E0
    participant "DispensasRouter\nPOST /dispensas" as DR
    participant "require_rol" as RR
    participant "SolicitudDispensaService" as SDS
    participant "politica_acceso" as PA
    participant "SolicitudDispensaRepository" as SDR
end box

database "SQLite" as DB

S   -> CP   : alumno, asignatura matriculada, motivo
CP  -> DS   : crear({alumno_id, asignatura_matriculada_id, motivo})
DS  -> DR   : POST /dispensas (Bearer)
DR  -> RR   : autorizar ["alumno", "secretaria"]
RR  --> DR  : Secretaria | 403
DR  -> SDS  : crear(datos, current_user)
SDS -> PA   : politica_para(Secretaria)
PA  --> SDS : PoliticaSecretaria
SDS -> SDR  : crear(alumno_id, asignatura_matriculada_id, motivo, responsable_id=current_user.id)
SDR -> DB   : INSERT (estado=PENDIENTE, fecha_solicitud=now)
DB  --> SDR : SolicitudDispensa
SDR --> SDS : SolicitudDispensa
SDS --> DR  : SolicitudDispensaOut
DR  --> DS  : 201
DS  --> CP  : creada
CP  --> S   : navigate("/dispensas/{id}")

@enduml
